# Required — generate with: openssl rand -hex 32
PAYLOAD_SECRET=
PREVIEW_SECRET=

# Database
# Local (no Docker): leave USE_SQLITE=true — creates portfolio.db
# Production: set USE_SQLITE=false and use Supabase Postgres URL
USE_SQLITE=true
DATABASE_URL=file:./portfolio.db
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/portfolio
# Only set true when you change Payload collections/schema (slow on cold start)
# PAYLOAD_DATABASE_PUSH=true

# Vercel Blob (optional in local; required in production)
BLOB_READ_WRITE_TOKEN=

# Contact notifications
# FormSubmit delivers to Gmail free (confirm once in inbox). Resend optional.
CONTACT_EMAIL_TO=malikabdulsattar9947@gmail.com
EMAIL_FORMSUBMIT=true
EMAIL_API_KEY=
EMAIL_FROM=

# CAPTCHA (optional)
CAPTCHA_SECRET_KEY=
NEXT_PUBLIC_CAPTCHA_SITE_KEY=

# Seed script
SEED_ADMIN_NAME=Admin
